# directly apply to a system like this:
# curl https://raw.github.com/stackmagic/random-utils/master/config-files/dot-gitconfig | sed "s/YOUR_NAME/ your name here /" | sed "s/YOUR_EMAIL/ your email here /" >> ~/.gitconfig

[user]
	name = YOUR_NAME
	email = YOUR_EMAIL
[core]
	editor = vim
[color]
	diff = auto
	status = auto
	branch = auto
[alias]
	ci = commit
	st = status -s -b
	co = checkout
	lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative
[pull]
        ff = only
[push]
        default = simple
        autoSetupRemote = true
[init]
        defaultBranch = master
[merge]
        renamelimit = 999999
[rebase]
        autosquash = true
[grep]
        lineNumber = true
[rerere]
        enabled = true
[diff]
        renamelimit = 999999
[diff "hex"]
        textconv = hexdump -v -C
